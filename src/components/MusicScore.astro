---
// MusicScore.astro - Display MusicXML scores in blog posts
// Usage: <MusicScore scoreId="example-score" title="Score Title" />

interface Props {
  scoreId: string;
  title?: string;
  class?: string;
}

const { scoreId, title, class: className } = Astro.props;
---

<div class={`music-score-container ${className || ''}`}>
  {title && <h3 class="music-score-title">{title}</h3>}
  <div id={`score-${scoreId}`} class="music-score-display"></div>
</div>

<script define:vars={{ scoreId }}>
  // ============================================================
  // Load OpenSheetMusicDisplay (UMD bundle) via a <script> tag.
  // The npm package is a UMD bundle that Vite cannot transform
  // for client-side dynamic import(), so we copy it to /public/js/
  // and load it as a classic script.
  // ============================================================

  const SCORE_ELEMENT_ID = `score-${scoreId}`;
  const OSMD_SCRIPT_URL = '/js/opensheetmusicdisplay.min.js';

  async function ensureOSMDLoaded() {
    // Return immediately if already loaded by another component
    if (window.opensheetmusicdisplay?.OpenSheetMusicDisplay) {
      return window.opensheetmusicdisplay.OpenSheetMusicDisplay;
    }

    return new Promise((resolve, reject) => {
      // Avoid inserting duplicate script tags
      if (document.querySelector(`script[src="${OSMD_SCRIPT_URL}"]`)) {
        // Another instance is already loading the script — wait for it
        const checkInterval = setInterval(() => {
          if (window.opensheetmusicdisplay?.OpenSheetMusicDisplay) {
            clearInterval(checkInterval);
            resolve(window.opensheetmusicdisplay.OpenSheetMusicDisplay);
          }
        }, 100);
        // Timeout after 15s
        setTimeout(() => {
          clearInterval(checkInterval);
          reject(new Error('OpenSheetMusicDisplay script load timed out'));
        }, 15000);
        return;
      }

      const script = document.createElement('script');
      script.src = OSMD_SCRIPT_URL;
      script.onload = () => {
        if (window.opensheetmusicdisplay?.OpenSheetMusicDisplay) {
          resolve(window.opensheetmusicdisplay.OpenSheetMusicDisplay);
        } else {
          reject(new Error('OpenSheetMusicDisplay script loaded but constructor not found'));
        }
      };
      script.onerror = () => reject(new Error('Failed to load OpenSheetMusicDisplay script'));
      document.head.appendChild(script);
    });
  }

  (async () => {
    const scoreElement = document.getElementById(SCORE_ELEMENT_ID);
    if (!scoreElement) return;

    try {
      const OpenSheetMusicDisplay = await ensureOSMDLoaded();
      scoreElement.innerHTML = '<p class="loading">Loading music score...</p>';

      const osmdInstance = new OpenSheetMusicDisplay(scoreElement, {
        autoResize: true,
        backend: 'svg',
        drawingParameters: 'default',
      });

      const response = await fetch(`/scores/${scoreId}.musicxml`);
      if (!response.ok) {
        scoreElement.innerHTML = `<p class="error">Error loading score: ${scoreId} (${response.status})</p>`;
        return;
      }

      const scoreData = await response.text();
      await osmdInstance.load(scoreData);
      osmdInstance.render();
    } catch (error) {
      console.error('Error rendering score:', error);
      scoreElement.innerHTML = `<p class="error">Failed to load music rendering library</p>`;
    }
  })();
</script>

<style>
  .music-score-container {
    margin: 2em 0;
    padding: 1.5em;
    border-radius: 8px;
    background-color: var(--background-body);
    border: 1px solid rgba(0, 0, 0, 0.1);
  }

  .music-score-title {
    margin-top: 0;
    margin-bottom: 1.2em;
    font-size: 1.5em;
    color: var(--text-main);
    border-bottom: 2px solid var(--primary-color);
    padding-bottom: 0.5em;
  }

  .music-score-display {
    width: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .music-score-display :global(svg) {
    max-width: 100%;
    height: auto;
  }

  .error {
    color: #d32f2f;
    font-family: var(--font-family-sans);
    text-align: center;
    padding: 2em;
  }

  .loading {
    color: var(--text-secondary);
    font-family: var(--font-family-sans);
    text-align: center;
    padding: 2em;
  }

  :root.theme-dark .music-score-container {
    background-color: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.1);
  }
</style>